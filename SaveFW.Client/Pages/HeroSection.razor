@inject IJSRuntime JSRuntime

<section class="relative w-full overflow-hidden min-h-[100svh]">
    <div class="mx-auto flex min-h-[100svh] w-full max-w-[96rem] flex-col items-center px-4 sm:px-6 lg:flex-row lg:px-8 xl:px-10">
        <!-- Text Content -->
        <div class="hero-copy flex-1 relative z-20 flex flex-col justify-center py-24 text-white lg:py-32 lg:pr-8 xl:pr-12">
            <h1 class="hero-headline text-4xl font-black leading-tight tracking-tight sm:text-5xl lg:text-6xl mb-6">
                <span class="hero-line">@RenderAnimatedText("DON'T LET THEM", 0.2, 0.055)</span>
                <span class="hero-line hero-line--accent text-accent underline decoration-4 decoration-accent/50 underline-offset-4">@RenderAnimatedText("GAMBLE AWAY", 1.25, 0.055)</span>
                <span class="hero-line">@RenderAnimatedText("OUR CITY'S", 2.3, 0.055)</span>
                <span class="hero-line">@RenderAnimatedText("FUTURE.", 3.15, 0.055)</span>
            </h1>
            <h2 class="hero-kicker text-2xl font-bold text-accent mb-6 uppercase tracking-wider">
                <span class="hero-kicker-part">@RenderAnimatedText("Fort Wayne", 4.2, 0.05)</span>
                <span class="hero-kicker-part">@RenderAnimatedText("Deserves Better.", 4.9, 0.05)</span>
            </h2>
            <p class="text-lg text-slate-200 font-medium leading-relaxed mb-10 max-w-xl">
                The proposed casino expansion creates a net fiscal loss for our city, introducing risks of addiction and
                increased crime. Save Fort Wayne has formed a coalition of the willing that bridges political and
                demographic divides. We invite you to join us in defending our community's financial health and
                safety.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
                <!-- Analysis Button -->

                <a class="flex min-h-[56px] w-full sm:w-auto items-center justify-center gap-2 rounded-lg bg-white text-fw-teal dark:text-slate-900 px-6 text-sm font-bold shadow-lg transition-transform active:scale-95 active:bg-slate-100 whitespace-nowrap animate-attention"
                    href="#" onclick="openFlipbook(event)">
                    <span class="material-symbols-outlined text-lg">description</span>
                    Read Independent Analysis
                </a>
                <!-- Email Button -->
                <a href="mailto:outreach@savefw.com"
                    class="flex min-h-[56px] w-full sm:w-auto items-center justify-center gap-2 rounded-lg bg-white text-fw-teal dark:text-slate-900 px-6 text-sm font-bold shadow-lg transition-transform active:scale-95 active:bg-slate-100 whitespace-nowrap">
                    <span class="material-symbols-outlined text-lg">mail</span>
                    Email Us: outreach@savefw.com
                </a>
            </div>

        </div>

        <!-- Image Side -->
        <div class="relative w-full lg:w-[55%]">
            <!-- Slot Machine (Moved Here) -->
            <div
                class="relative max-w-[900px] mx-auto z-0 scale-75 sm:scale-90 lg:scale-100 origin-top lg:origin-center mt-6 lg:mt-10">
                <!-- LEVER -->
                <!-- LEVER BASE (Layered Behind) -->
                <div class="lever-container" style="z-index: 0;">
                    <div class="lever-base"></div>
                </div>

                <div class="slot-machine-wrapper">
                    <!-- Siren Light -->
                    <div class="siren-wrapper" id="siren">
                        <div class="siren-base"></div>
                        <div class="siren-bulb"></div>
                    </div>

                    <!-- Marquee Logo -->
                    <div class="marquee-logo">
                        <img src="assets/SAVEFW.svg" alt="Save Fort Wayne" />
                    </div>

                    <!-- Individual Light Bulbs (Generated by JS) -->
                    <ul class="casino-lights" id="casino-lights"></ul>

                    <!-- Window with Payline Markers -->
                    <div class="relative max-w-[650px] mx-auto">
                        <!-- Left Marker -->
                        <div class="payline-marker marker-left">
                            <div class="marker-base"></div>
                            <div class="marker-tip"></div>
                        </div>

                        <!-- Right Marker -->
                        <div class="payline-marker marker-right">
                            <div class="marker-base"></div>
                            <div class="marker-tip"></div>
                        </div>

                        <div class="slot-window">
                            <div class="reel-container">
                                <div class="reel-strip" id="reel-1">
                                </div>
                                <div class="reel-overlay"></div>
                            </div>

                            <div class="reel-container">
                                <div class="reel-strip" id="reel-2"></div>
                                <div class="reel-overlay"></div>
                            </div>

                            <div class="reel-container">
                                <div class="reel-strip" id="reel-3"></div>
                                <div class="reel-overlay"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Reel Control Buttons -->
                    <div class="reel-controls">
                        <button class="reel-btn" @onclick="() => SpinReel(0)">SPIN</button>
                        <button class="reel-btn" @onclick="() => SpinReel(1)">SPIN</button>
                        <button class="reel-btn" @onclick="() => SpinReel(2)">SPIN</button>
                    </div>

                    <!-- Coin Tray (centered) -->
                    <div class="coin-tray">
                        <div class="coin-tray-inner">
                            <div class="coin-tray-floor"></div>
                        </div>
                    </div>

                    <!-- Right Side Panel: Credit Counter + Coin Insert -->
                    <div class="coin-panel">
                        <!-- Credit Counter -->
                        <div class="credit-counter">
                            <span class="credit-label">CREDITS</span>
                            <span class="credit-value" id="credit-display">02</span>
                        </div>

                        <!-- Coin Insert Slot -->
                        <div class="coin-insert" onclick="window.SlotMachine.insertCoin()">
                            <div class="coin-insert-inner">
                                <span class="coin-price">25¢</span>
                                <span class="coin-text">INSERT<br/>COIN TO</span>
                                <span class="coin-play">PLAY</span>
                            </div>
                            <div class="coin-slot">
                                <div class="coin-slot-opening"></div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- LEVER ARM (Layered In Front) -->
                <div class="lever-container" style="z-index: 20; pointer-events: none;">
                    <div class="lever-arm" id="slot-lever" style="pointer-events: auto;">
                        <div class="lever-knob">
                            <span class="knob-text">CLICK<br>OR<br>PULL</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private RenderFragment RenderAnimatedText(string text, double startDelaySeconds, double charStepSeconds) => builder =>
    {
        for (var i = 0; i < text.Length; i++)
        {
            builder.OpenElement(i * 2, "span");
            builder.AddAttribute(i * 2 + 1, "class", "hero-char");
            builder.AddAttribute(i * 2 + 2, "style", $"--hero-delay: {(startDelaySeconds + (i * charStepSeconds)).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}s;");
            builder.AddContent(i * 2 + 3, text[i].ToString());
            builder.CloseElement();
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("window.SlotMachine.init");
        }
    }

    private async Task SpinReel(int index)
    {
        await JSRuntime.InvokeVoidAsync("window.spinReel", index);
    }
}
