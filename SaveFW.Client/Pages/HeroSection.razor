@inject IJSRuntime JSRuntime

<section id="hero-section" class="relative w-full overflow-hidden min-h-[100svh] mobile-sequence-pending">
    <div class="hero-layout mx-auto flex min-h-[100svh] w-full max-w-[96rem] flex-col items-center px-4 sm:px-6 lg:flex-row lg:px-8 xl:px-10">
        <!-- Text Content -->
        <div class="hero-copy flex-1 relative z-20 flex flex-col justify-center py-24 text-white lg:py-32 lg:pr-8 xl:pr-12">
            <div class="hero-mobile-intro">
                <h1 class="hero-headline text-4xl font-black leading-tight tracking-tight sm:text-5xl lg:text-6xl mb-6">
                    <span class="hero-line">
                        <span class="hero-animate" style="display: inline-block; opacity: 0; animation: fadeInUp 1.45s ease 0.45s forwards;">DON'T LET THEM</span>
                    </span>
                    <span class="hero-line">
                        <span class="hero-animate hero-line--accent text-accent underline decoration-4 decoration-accent/50 underline-offset-4" style="display: inline-block; opacity: 0; animation: fadeInUp 1.45s ease 1.05s forwards;">GAMBLE AWAY</span>
                    </span>
                    <span class="hero-line">
                        <span class="hero-animate" style="display: inline-block; opacity: 0; animation: fadeInUp 1.45s ease 1.65s forwards;">OUR CITY'S</span>
                    </span>
                    <span class="hero-line">
                        <span class="hero-animate" style="display: inline-block; opacity: 0; animation: fadeInUp 1.45s ease 2.25s forwards;">FUTURE.</span>
                    </span>
                </h1>
                <h2 class="hero-kicker text-2xl font-bold text-accent mb-6 uppercase tracking-wider">
                    <span class="hero-kicker-part">
                        <span class="hero-animate" style="display: inline-block; opacity: 0; animation: fadeInUp 1.45s ease 3s forwards;">Fort Wayne</span>
                    </span>
                    <span class="hero-kicker-part">
                        <span class="hero-animate" style="display: inline-block; opacity: 0; animation: fadeInUp 1.45s ease 3.6s forwards;">Deserves Better.</span>
                    </span>
                </h2>
            </div>
            <p class="hero-tagline text-lg text-slate-200 font-medium leading-relaxed mb-10 max-w-xl">
                <span class="hero-animate" style="display: inline-block; opacity: 0; animation: fadeInUp 1.5s ease 2s both;">
                The proposed casino expansion creates a net fiscal loss for our city, introducing risks of addiction and
                increased crime. Save Fort Wayne has formed a coalition of the willing that bridges political and
                demographic divides. We invite you to join us in defending our community's financial health and
                safety.
                </span>
            </p>

            <a href="#mayor-critique" class="hero-desktop-learn-more hidden lg:flex" aria-label="Learn more and continue to the next section">
                <span class="hero-desktop-learn-more-text">Learn More</span>
                <span class="hero-desktop-learn-more-circle" aria-hidden="true">
                    <span class="hero-desktop-learn-more-chevron">v</span>
                </span>
            </a>
        </div>

        <!-- Image Side -->
        <div class="hero-visual-stage relative w-full lg:w-[55%]">
            <!-- Slot Machine (Moved Here) -->
            <div class="hero-slot-shell relative mx-auto z-0 mt-6">
                <!-- LEVER -->
                <!-- LEVER BASE (Layered Behind) -->
                <div class="lever-container" style="z-index: 0;">
                    <div class="lever-base"></div>
                </div>

                <div class="slot-machine-wrapper">
                    <!-- Siren Light -->
                    <div class="siren-wrapper" id="siren">
                        <div class="siren-base"></div>
                        <div class="siren-bulb"></div>
                    </div>

                    <!-- Marquee Logo -->
                    <div class="marquee-logo">
                        <img src="assets/SAVEFW.svg" alt="Save Fort Wayne" />
                    </div>

                    <!-- Individual Light Bulbs (Generated by JS) -->
                    <ul class="casino-lights" id="casino-lights"></ul>

                    <!-- Window with Payline Markers -->
                    <div class="relative max-w-[650px] mx-auto">
                        <!-- Left Marker -->
                        <div class="payline-marker marker-left">
                            <div class="marker-base"></div>
                            <div class="marker-tip"></div>
                        </div>

                        <!-- Right Marker -->
                        <div class="payline-marker marker-right">
                            <div class="marker-base"></div>
                            <div class="marker-tip"></div>
                        </div>

                        <div class="slot-window">
                            <div class="reel-container">
                                <div class="reel-strip" id="reel-1">
                                </div>
                                <div class="reel-overlay"></div>
                            </div>

                            <div class="reel-container">
                                <div class="reel-strip" id="reel-2"></div>
                                <div class="reel-overlay"></div>
                            </div>

                            <div class="reel-container">
                                <div class="reel-strip" id="reel-3"></div>
                                <div class="reel-overlay"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Reel Control Buttons -->
                    <div class="reel-controls">
                        <button class="reel-btn" @onclick="() => SpinReel(0)">PUSH</button>
                        <button class="reel-btn" @onclick="() => SpinReel(1)">PUSH</button>
                        <button class="reel-btn" @onclick="() => SpinReel(2)">PUSH</button>
                    </div>

                    <!-- Coin Tray (centered) -->
                    <div class="coin-tray">
                        <div class="coin-tray-inner">
                            <div class="coin-tray-floor"></div>
                        </div>
                    </div>

                    <!-- Right Side Panel: Credit Counter + Coin Insert -->
                    <div class="coin-panel">
                        <!-- Credit Counter -->
                        <div class="credit-counter">
                            <span class="credit-label">CREDITS</span>
                            <span class="credit-value" id="credit-display">02</span>
                        </div>

                        <!-- Coin Insert Slot -->
                        <div class="coin-insert" onclick="window.SlotMachine.insertCoin()">
                            <div class="coin-insert-inner">
                                <span class="coin-price">25¢</span>
                                <span class="coin-text">INSERT<br/>COIN TO</span>
                                <span class="coin-play">PLAY</span>
                            </div>
                            <div class="coin-slot">
                                <div class="coin-slot-opening"></div>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="hero-mobile-play-hint" aria-hidden="true">
                    <span class="hint-arrow">v</span>
                    <span class="hint-text">PUSH TO PLAY OR SCROLL DOWN TO LEARN MORE</span>
                </div>

                <!-- LEVER ARM (Layered In Front) -->
                <div class="lever-container" style="z-index: 20; pointer-events: none;">
                    <div class="lever-arm" id="slot-lever" style="pointer-events: auto;" role="button" tabindex="0" aria-label="Spin by clicking or pulling the lever">
                        <div class="lever-knob">
                            <span class="knob-text">CLICK<br>OR<br>PULL</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("slotMachineSafeInit", 1023, 10000);
        }
    }

    private async Task SpinReel(int index)
    {
        await JSRuntime.InvokeVoidAsync("window.spinReel", index);
    }
}
