@page "/"
@inject IJSRuntime JSRuntime
@using SaveFW.Client.Pages

<div class="home-page">
    <section class="home-hero-gradient" id="home-hero-gradient">
        <div class="home-hero-shell">
            <HeroSection />
        </div>
    </section>

    <header class="home-sticky-header-shell" id="home-sticky-header">
        <nav class="home-sticky-header-nav w-full text-white">
            <div class="home-sticky-header-inner w-full px-4 py-3 sm:px-6 lg:px-8">
                <div class="home-sticky-brand min-h-14 items-center justify-between gap-4">
                    <a class="flex items-center gap-3 group shrink-0" href="#home-hero-gradient">
                        <img src="assets/SAVEFW_DARK_MODE.svg" alt="Save Fort Wayne" class="h-12 w-auto object-contain" />
                    </a>
                </div>
                <div class="home-sticky-header-links min-w-0">
                    <div class="home-sticky-header-links-track flex items-center gap-5 lg:gap-6 xl:gap-8">
                        <a class="home-sticky-link text-sm font-semibold text-white/90 hover:text-white transition-colors whitespace-nowrap"
                           href="#home-hero-gradient"><span class="home-sticky-link-label">Home</span></a>
                        <a class="home-sticky-link text-sm font-semibold text-white/90 hover:text-white transition-colors whitespace-nowrap"
                           href="#mayor-critique"><span class="home-sticky-link-label">Decoding The Spin</span></a>
                        <a class="home-sticky-link text-sm font-semibold text-white/90 hover:text-white transition-colors whitespace-nowrap"
                           href="#economic-analysis"><span class="home-sticky-link-label">Economic Impact Calculator</span></a>
                        <a class="home-sticky-link text-sm font-semibold text-white/90 hover:text-white transition-colors whitespace-nowrap"
                           href="#economic-analysis-part-2"><span class="home-sticky-link-label">Substitution Effect</span></a>
                        <a class="home-sticky-link text-sm font-semibold text-white/90 hover:text-white transition-colors whitespace-nowrap"
                           href="#tribal-analysis"><span class="home-sticky-link-label">Tribal Fact Check</span></a>
                        <a class="home-sticky-link text-sm font-semibold text-white/90 hover:text-white transition-colors whitespace-nowrap"
                           href="#crime-safety"><span class="home-sticky-link-label">Crime & Safety</span></a>
                        <a href="https://github.com/tuckthomas/casino-economic-impact-calculator.git" target="_blank" rel="noopener noreferrer"
                           class="home-sticky-link home-sticky-link--icon home-sticky-icon-link home-sticky-mobile-only rounded-lg border border-white/20 text-white/90 hover:text-white transition-colors"
                           title="View Source on GitHub" aria-label="View Source on GitHub">
                            <svg class="home-sticky-github-icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill-rule="evenodd" clip-rule="evenodd"
                                      fill="currentColor"
                                      d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z">
                                </path>
                            </svg>
                        </a>
                    </div>
                </div>
                <div class="items-center home-sticky-desktop-only">
                    <a href="https://github.com/tuckthomas/casino-economic-impact-calculator.git" target="_blank" rel="noopener noreferrer"
                       class="home-sticky-icon-link rounded-lg border border-white/20 text-white/90 hover:text-white transition-colors"
                       title="View Source on GitHub" aria-label="View Source on GitHub">
                        <svg class="home-sticky-github-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill-rule="evenodd" clip-rule="evenodd"
                                  fill="currentColor"
                                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z">
                            </path>
                        </svg>
                    </a>
                </div>
            </div>
        </nav>
    </header>
    <div class="home-sticky-header-spacer" id="home-sticky-header-spacer" aria-hidden="true"></div>

    <MayorCritique />
    <EconomicImpact />
    <TribalAnalysis />
    <CrimeSafety />
    <Footer />
    <Modals />
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("window.HomeHeader.init");
        }
    }
}
