@code {
    private List<DropdownItem> StateOptions = new();
    private List<DropdownItem> CountyOptions = new();
    private string? SelectedStateId;
    private string? SelectedCountyId;
    private DotNetObjectReference<Map>? _objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            
            // Register JS→Blazor callbacks for map events
            await JSRuntime.InvokeVoidAsync("window.registerMapDropdownSync", _objRef);
            
            await JSRuntime.InvokeVoidAsync("window.MapLibreImpactMap.init", "impact-map");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            Console.WriteLine("Map: Fetching states from API...");
            var data = await Http.GetFromJsonAsync<CensusFeatureCollection>("/api/census/states");
            Console.WriteLine($"Map: Got data, Features count: {data?.Features?.Count ?? 0}");
            if (data?.Features != null && data.Features.Count > 0)
            {
                StateOptions = data.Features.Select(f => new DropdownItem
                {
                    Value = f.Properties.GeoId,
                    Text = f.Properties.Name,
                    Badge = f.Properties.PopTotal > 0 ? f.Properties.PopTotal.ToString("N0") : "N/A",
                    OrderValue = f.Properties.PopTotal
                }).OrderBy(i => i.Text).ToList();
                Console.WriteLine($"Map: StateOptions populated with {StateOptions.Count} items");
                StateHasChanged();
            }
            else
            {
                Console.WriteLine("Map: No features found in response");
            }
        }
        catch (Exception ex) { Console.WriteLine($"Map Error loading states: {ex}"); }
    }

    [JSInvokable]
    public async Task OnMapStateSelected(string stateFips, string stateName)
    {
        // Map selected a state - update dropdown
        SelectedStateId = stateFips;
        
        // Load counties for this state
        try
        {
            var data = await Http.GetFromJsonAsync<CensusFeatureCollection>($"/api/census/counties/{stateFips}");
            if (data?.Features != null)
            {
                CountyOptions = data.Features.Select(f => new DropdownItem
                {
                    Value = f.Properties.GeoId,
                    Text = f.Properties.Name,
                    Badge = f.Properties.PopTotal > 0 ? f.Properties.PopTotal.ToString("N0") : "N/A",
                    OrderValue = f.Properties.PopTotal
                }).OrderBy(i => i.Text).ToList();
            }
            else 
            {
                CountyOptions.Clear();
            }
            SelectedCountyId = "";
        }
        catch (Exception ex) { Console.WriteLine($"Error loading counties for map sync: {ex}"); }
        
        StateHasChanged();
    }

    [JSInvokable]
    public void OnMapCountySelected(string countyFips, string countyName)
    {
        // Map selected a county - update dropdown
        SelectedCountyId = countyFips;
        StateHasChanged();
    }

    private async Task OnStateSelected(DropdownItem item)
    {
        SelectedStateId = item.Value;
        
        // Load Counties
        try
        {
            // Reset UI for Step 2
            await JSRuntime.InvokeVoidAsync("window.MapLibreImpactMap.navigateToStep", 2);

            var data = await Http.GetFromJsonAsync<CensusFeatureCollection>($"/api/census/counties/{item.Value}");
            if (data?.Features != null)
            {
                CountyOptions = data.Features.Select(f => new DropdownItem
                {
                    Value = f.Properties.GeoId,
                    Text = f.Properties.Name,
                    Badge = f.Properties.PopTotal > 0 ? f.Properties.PopTotal.ToString("N0") : "N/A",
                    OrderValue = f.Properties.PopTotal
                }).OrderBy(i => i.Text).ToList();
            }
            else 
            {
                CountyOptions.Clear();
            }
            
            // Reset County Selection
            SelectedCountyId = "";
            
            // Trigger Map Update
            await JSRuntime.InvokeVoidAsync("window.MapLibreImpactMap.loadState", item.Value);
        }
        catch (Exception ex) { Console.WriteLine($"Error loading counties: {ex}"); }
    }

    private async Task OnCountySelected(DropdownItem item)
    {
        SelectedCountyId = item.Value;
        await JSRuntime.InvokeVoidAsync("window.MapLibreImpactMap.loadCounty", item.Value);
    }
    
    public void Dispose()
    {
        _objRef?.Dispose();
    }

    // JSON Models
    public class CensusFeatureCollection
    {
        [System.Text.Json.Serialization.JsonPropertyName("features")]
        public List<CensusFeature> Features { get; set; } = new();
    }
    public class CensusFeature
    {
        [System.Text.Json.Serialization.JsonPropertyName("properties")]
        public CensusProperties Properties { get; set; } = new();
    }
    public class CensusProperties
    {
        [System.Text.Json.Serialization.JsonPropertyName("geoid")]
        public string GeoId { get; set; } = "";

        [System.Text.Json.Serialization.JsonPropertyName("name")]
        public string Name { get; set; } = "";

        [System.Text.Json.Serialization.JsonPropertyName("pop_total")]
        public long PopTotal { get; set; }
    }
