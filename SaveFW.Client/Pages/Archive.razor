@page "/archive"

<PageTitle>Archive | Save Fort Wayne</PageTitle>

<section class="min-h-screen bg-slate-950 text-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="mb-10 max-w-3xl">
            <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-slate-400">Archive</p>
            <h1 class="mb-4 text-4xl font-black tracking-tight sm:text-5xl">Independent Analysis Archive</h1>
            <p class="text-lg leading-relaxed text-slate-300">
                Archived reports and supporting documents live here. The independent analysis PDF is available below.
            </p>
        </div>

        <div class="rounded-3xl border border-slate-800 bg-slate-900/80 p-6 shadow-2xl shadow-slate-950/40 backdrop-blur-sm sm:p-8">
            <div class="mb-6 flex flex-col gap-4 border-b border-slate-800 pb-6 sm:flex-row sm:items-start sm:justify-between">
                <div>
                    <h2 class="text-2xl font-bold text-white">Independent Analysis</h2>
                    <p class="mt-2 text-sm leading-relaxed text-slate-400">
                        Allen County casino analysis PDF archived for public reference.
                    </p>
                </div>
                <div class="flex flex-col gap-3 sm:flex-row">
                    <a href="assets/Independent_Analysis_Allen_County_Casino.pdf" target="_blank"
                       class="inline-flex min-h-12 items-center justify-center rounded-lg bg-white px-5 text-sm font-semibold text-slate-900 transition-colors hover:bg-slate-100">
                        Open PDF
                    </a>
                    <a href="assets/Independent_Analysis_Allen_County_Casino.pdf" download
                       class="inline-flex min-h-12 items-center justify-center rounded-lg border border-slate-700 px-5 text-sm font-semibold text-slate-200 transition-colors hover:border-slate-500 hover:text-white">
                        Download PDF
                    </a>
                </div>
            </div>

            <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-950">
                <iframe
                    src="assets/Independent_Analysis_Allen_County_Casino.pdf"
                    title="Independent Analysis PDF"
                    class="h-[75vh] w-full"
                ></iframe>
            </div>
        </div>
    </div>
</section>
